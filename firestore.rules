rules_version = '2';

// ============================================================
// Danji Pass — Firestore 보안 규칙
//
// 읽기: 누구나 가능 (조회 기능은 인증 없이 동작해야 함)
// 쓰기: 누구나 가능 (현재 구조상 클라이언트 비밀번호만으로 보호됨)
//
// ⚠️ 한계: 관리자 비밀번호는 index.html 내 JS 코드에 평문으로 있어
//         브라우저 개발자도구로 누구나 확인 가능합니다.
//         이는 "실수로 일반 사용자가 업로드 버튼을 못 누르게" 막는
//         수준의 보호이며, 악의적 공격자를 막는 보안 수준은 아닙니다.
//         진짜 보안이 필요하면 Firebase Authentication 도입 필요
//         (다음 단계로 안내 가능)
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {
    match /danjiPass/{document=**} {
      allow read: if true;
      allow write: if true;
    }
  }
}
